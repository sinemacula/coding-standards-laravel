<?xml version="1.0"?>
<ruleset name="SineMaculaLaravel">

    <description>Sine Macula coding standard for Laravel projects.</description>

    <!--
        Pull in the full framework-agnostic SineMacula standard so a Laravel project
        references a single standard (`SineMaculaLaravel`) and gets both layers. The
        sinemacula/coding-standards package must be installed alongside this one.
    -->
    <rule ref="SineMacula"/>

    <!--
        Laravel-specific sniffs live in this standard's Sniffs/ directory and are
        auto-discovered by PHP_CodeSniffer - no <rule ref> lines are needed for them.
    -->

</ruleset>
