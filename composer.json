{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "sinemacula/coding-standards-laravel",
    "type": "phpcodesniffer-standard",
    "license": "Apache-2.0",
    "description": "Laravel-specific coding standards, static-analysis rules, and code-quality tooling for Sine Macula's Laravel repositories.",
    "authors": [
        {
            "name": "Ben Carey",
            "email": "bdmc@sinemacula.co.uk"
        }
    ],
    "require": {
        "php": "^8.3",
        "composer/semver": "^3.0",
        "sinemacula/coding-standards": "^1.19.1",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "suggest": {
        "phpstan/phpstan-phpunit": "PHPUnit-aware PHPStan rules. Auto-registers via phpstan/extension-installer.",
        "phpstan/extension-installer": "Auto-registers the Laravel PHPStan rules (required for the shared php/phpstan-laravel.neon to load)."
    },
    "autoload": {
        "psr-4": {
            "SineMacula\\CodingStandardsLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SineMaculaLaravel\\Tests\\": "SineMaculaLaravel/Tests/"
        }
    },
    "extra": {
        "phpstan": {
            "includes": [
                "php/phpstan-laravel.neon"
            ]
        }
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.13",
        "slevomat/coding-standard": "^8.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "infection/infection": "^0.33.2",
        "phpunit/phpunit": "^12",
        "phpstan/phpstan": "^2.1",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-phpunit": "^2.0",
        "symfony/console": "^7.4"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "infection/extension-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "check": [
            "qlty check"
        ],
        "format": [
            "qlty fmt"
        ],
        "smells": [
            "qlty smells"
        ],
        "analyse": [
            "@php vendor/bin/phpstan analyse"
        ],
        "test": [
            "@php vendor/bin/phpunit"
        ],
        "test:coverage": [
            "@php -d pcov.enabled=0 -d xdebug.mode=coverage vendor/bin/phpunit --coverage-clover=clover.xml"
        ],
        "test:mutation": [
            "@php -d memory_limit=-1 -d pcov.enabled=0 -d xdebug.mode=coverage vendor/bin/infection --configuration=infection.json5 --only-covering-test-cases --threads=max --git-diff-lines --git-diff-base=origin/master --map-source-class-to-test --min-msi=85 --min-covered-msi=85 --ignore-msi-with-no-mutations"
        ],
        "test:mutation:full": [
            "@php -d memory_limit=-1 -d pcov.enabled=0 -d xdebug.mode=coverage vendor/bin/infection --configuration=infection.full.json5 --only-covering-test-cases --threads=max"
        ]
    },
    "scripts-descriptions": {
        "check": "Run static analysis and lint checks via qlty.",
        "format": "Format codebase using qlty.",
        "smells": "Report code smells (duplication, complexity) via qlty.",
        "analyse": "Run PHPStan over the repo's own sniffs and rules (phpstan.neon.dist).",
        "test": "Run the PHPUnit sniff/rule test suite.",
        "test:coverage": "Run the PHPUnit suite with Clover coverage output (requires Xdebug).",
        "test:mutation": "Run the Infection mutation-testing gate against the MSI thresholds.",
        "test:mutation:full": "Run the full Infection mutation suite without MSI thresholds."
    }
}
