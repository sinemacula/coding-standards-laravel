# ==============================================================================
# Laravel-specific PHPStan rules for Sine Macula projects.
# ==============================================================================
#
# This file is auto-included in consuming projects via the package's
# `extra.phpstan.includes` (resolved by phpstan/extension-installer). It carries
# ONLY Laravel-specific custom rules - the framework-agnostic PHPStan config is
# provided separately by sinemacula/coding-standards' own php/phpstan.neon.
#
# Register Laravel rule classes (from src/PHPStan/Rules/) under `rules:`. They
# are Composer-autoloaded via the `SineMacula\CodingStandardsLaravel\` PSR-4 map,
# so they load in a consumer's PHPStan run exactly as the base rules do.
parameters:
    sineMaculaLaravel:
        # Attribute names PreferModelAttributesRule mandates. Defaults to the
        # expressive set added in Laravel 13.2; set it to the attributes your
        # minimum version provides (e.g. the ObservedBy/ScopedBy/CollectedBy
        # family from 11). Use `modelAttributes!:` to replace, not append.
        modelAttributes:
            - Table
            - Fillable
            - Hidden

        # Explicit minimum Laravel version for the 13.2-only attributes
        # (#[Table]/#[Fillable]/#[Hidden]). Leave empty to detect it from the
        # nearest composer.json; set e.g. "13.2" to enforce them regardless.
        minLaravelVersion: ''

parametersSchema:
    sineMaculaLaravel: structure([
        modelAttributes: listOf(string())
        minLaravelVersion: string()
    ])

rules:
    - SineMacula\CodingStandardsLaravel\PHPStan\Rules\DisallowCastsPropertyRule
    - SineMacula\CodingStandardsLaravel\PHPStan\Rules\DisallowDatesPropertyRule
    - SineMacula\CodingStandardsLaravel\PHPStan\Rules\DisallowFactoryTimestampsRule
    - SineMacula\CodingStandardsLaravel\PHPStan\Rules\RequireFormRequestRulesRule
    - SineMacula\CodingStandardsLaravel\PHPStan\Rules\RequireMassAssignmentDeclarationRule
    - SineMacula\CodingStandardsLaravel\PHPStan\Rules\RequireMigrationMethodsRule
    - SineMacula\CodingStandardsLaravel\PHPStan\Rules\RequireRelationshipReturnTypeRule
    - SineMacula\CodingStandardsLaravel\PHPStan\Rules\RequireSnakeCaseResourceFieldsRule
    - SineMacula\CodingStandardsLaravel\PHPStan\Rules\RequireSnakeCaseSchemaRule

# PreferModelAttributesRule is registered as a service (not under `rules:`) so
# its mandated attribute set can be injected from the parameter above.
services:
    -
        class: SineMacula\CodingStandardsLaravel\PHPStan\Rules\PreferModelAttributesRule
        arguments:
            attributes: %sineMaculaLaravel.modelAttributes%
            minLaravelVersion: %sineMaculaLaravel.minLaravelVersion%
        tags:
            - phpstan.rules.rule
