# Dogfood the SineMacula PHPStan standard on this repo's own sniffs. Run in CI
# (GitHub Actions) and locally via `composer analyse`, where the full Composer
# vendor is installed. NOT run via qlty: qlty Cloud never runs `composer install`,
# so it cannot scan PHP_CodeSniffer's (non-PSR-4) source that the sniff code
# depends on. The framework-agnostic SineMacula PHPStan config is auto-included
# from the installed sinemacula/coding-standards package via extension-installer.
parameters:
    level: 9

    # PHP_CodeSniffer ships a bespoke autoloader (its classes are not on the
    # Composer classmap), so its source is scanned explicitly.
    scanDirectories:
        - vendor/squizlabs/php_codesniffer/src

    paths:
        - src
        - SineMaculaLaravel/Sniffs
        - SineMaculaLaravel/Tests

    ignoreErrors:
        # PHP_CodeSniffer exposes token data as mixed, so sniff code that reads,
        # iterates and accumulates token values trips these level-9 mixed checks.
        - identifier: offsetAccess.invalidOffset
        - identifier: binaryOp.invalid
        - identifier: assignOp.invalid
        - identifier: postInc.type
        - identifier: foreach.nonIterable
