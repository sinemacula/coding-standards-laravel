<?xml version="1.0"?>
<ruleset name="SineMaculaLaravel Project">

    <!--
        Dogfood the shared SineMacula standard on this repo's own PHP_CodeSniffer
        extension code. The standard is consumed as a Composer package, so it is
        referenced by its installed name (qlty installs it into the phpcs tool
        sandbox via composer.json's package_filters).
    -->
    <rule ref="SineMacula"/>

    <file>../../src</file>
    <file>../../SineMaculaLaravel/Sniffs</file>
    <file>../../SineMaculaLaravel/Tests</file>

    <!--
        Scoped exemptions for this repo's PHP_CodeSniffer extension code. The
        shared standard targets application code; these rules are physically
        impossible to satisfy in sniff code.

        - ParameterTypeHint / ScalarTypeHintMissing: PHP_CodeSniffer's
        Sniff::process(File $phpcsFile, $stackPtr) interface leaves $stackPtr
        untyped, and PHP fatals if an implementation narrows it to int.
        - RequireReadonlyPublicProperty: PHP_CodeSniffer assigns sniff
        configuration properties from the ruleset at runtime, so they cannot
        be readonly.
    -->
    <rule ref="SlevomatCodingStandard.TypeHints.ParameterTypeHint">
        <exclude-pattern>*/Sniffs/*</exclude-pattern>
    </rule>
    <rule ref="Squiz.Commenting.FunctionComment.ScalarTypeHintMissing">
        <exclude-pattern>*/Sniffs/*</exclude-pattern>
    </rule>
    <rule ref="SineMacula.Classes.RequireReadonlyPublicProperty">
        <exclude-pattern>*/Sniffs/*</exclude-pattern>
    </rule>

    <!--
        Every PHP file in this repo is tooling (sniffs and their tests) that
        handles arbitrary token and configuration values, so the no-mixed rule
        cannot be satisfied here.
    -->
    <rule ref="SlevomatCodingStandard.TypeHints.DisallowMixedTypeHint">
        <exclude-pattern>*/src/*</exclude-pattern>
        <exclude-pattern>*/Sniffs/*</exclude-pattern>
        <exclude-pattern>*/Tests/*</exclude-pattern>
    </rule>

</ruleset>
