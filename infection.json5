{
    $schema: "./vendor/infection/infection/resources/schema.json",
    source: {
        directories: [
            "src",
            "SineMaculaLaravel/Sniffs"
        ]
    },
    logs: {
        summary: "build/infection-summary.log",
        text: "build/infection.log"
    },
    phpUnit: {
        configDir: ".",
        customPath: "vendor/bin/phpunit"
    },
    initialTestsPhpOptions: "-d pcov.enabled=0 -d xdebug.mode=coverage -d memory_limit=1G",
    timeout: 30,
    mutators: {
        "@default": true
    }
}
